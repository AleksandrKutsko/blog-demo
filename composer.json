{
    "name": "blog/demo-project",
    "description": "Test blog project",
    "type": "project",
    "require": {
        "smarty/smarty": "^5.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "echo 'Smarty installed successfully!'"
        ],
        "test": "vendor/bin/phpunit",
        "test:unit": "vendor/bin/phpunit --testsuite Unit",
        "test:integration": "vendor/bin/phpunit --testsuite Integration",
        "test:coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "minimum-stability": "stable",
    "authors": [
        {
            "name": "Aleksandr Kutsko",
            "email": "sadik1997@yandex.ru"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
